---
const logos = [
  { src: "https://www.figma.com/api/mcp/asset/b3ebcecc-99e6-4bb3-bce1-56d8bac1d529", alt: "Partner logo", w: 98,  h: 78 },
  { src: "https://www.figma.com/api/mcp/asset/a7adeffb-c184-4625-877f-cea4a472d5eb", alt: "Partner logo", w: 85,  h: 82 },
  { src: "https://www.figma.com/api/mcp/asset/c1d39028-4f68-417f-b24b-4565dacc308f", alt: "Partner logo", w: 140, h: 80 },
  { src: "https://www.figma.com/api/mcp/asset/bdce1bfa-88af-47c2-ac85-7c1ec6a49fc7", alt: "Partner logo", w: 140, h: 80 },
  { src: "https://www.figma.com/api/mcp/asset/8e735670-6e83-44bb-ac25-37831b8acc11", alt: "Partner logo", w: 140, h: 80 },
];
// Duplicate for seamless infinite loop
const doubled = [...logos, ...logos];
---

<div class="partners-wrapper">
  <div class="divider-blue"></div>
  <section class="partners-section">
    <p class="partners-label overline" data-animate>PARTNERS</p>
    <div class="carousel-viewport">
      <div class="carousel-track">
        {doubled.map((logo) => (
          <div class="partner-logo-wrap">
            <img
              src={logo.src}
              alt={logo.alt}
              width={logo.w}
              height={logo.h}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
  <div class="divider-blue"></div>
</div>

<style>
.partners-wrapper {
  background: var(--bone-100);
}

.partners-section {
  display: flex;
  align-items: center;
  gap: 48px;
  padding: 28px 128px;
  min-height: 110px;
  overflow: hidden;
}

.partners-label {
  flex-shrink: 0;
  color: var(--navy-500);
}

/* Viewport clips the track; masks fade the edges */
.carousel-viewport {
  flex: 1;
  overflow: hidden;
  -webkit-mask-image: linear-gradient(
    to right,
    transparent,
    black 10%,
    black 90%,
    transparent
  );
  mask-image: linear-gradient(
    to right,
    transparent,
    black 10%,
    black 90%,
    transparent
  );
}

.carousel-track {
  display: flex;
  align-items: center;
  gap: 72px;
  width: max-content;
  animation: logos-scroll 24s linear infinite;
}

.carousel-track:hover {
  animation-play-state: paused;
}

@keyframes logos-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.partner-logo-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  filter: grayscale(0.25);
  opacity: 0.8;
  transition: filter 0.25s, opacity 0.25s;
}

.partner-logo-wrap:hover {
  filter: none;
  opacity: 1;
}

.partner-logo-wrap img {
  max-height: 64px;
  width: auto;
  object-fit: contain;
  display: block;
}

@media (max-width: 768px) {
  .partners-section {
    flex-direction: column;
    padding: 24px 0;
    gap: 20px;
  }
  .carousel-viewport {
    width: 100%;
  }
}
</style>
