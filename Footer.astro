---
const footerLinks = {
  Product: ["Overview", "Specifications", "Installation", "FAQ"],
  Company: ["Our Team", "Partners", "Press", "Careers"],
  Contact: ["Get a Quote", "Support", "info@raccodynamx.ca"],
};
---
<footer class="footer">
  <div class="footer-accent-top"></div>
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-logo"><span style="color: var(--navy-300);">R</span>ACCODYNAMX</p>
      <p class="footer-tagline">Centralized Level 2 EV Charging</p>
    </div>
    {Object.entries(footerLinks).map(([section, links]) => (
      <div class="footer-col">
        <p class="footer-col-title">{section}</p>
        {links.map(link => (
          <a href="#" class="footer-link">{link}</a>
        ))}
      </div>
    ))}
  </div>
  <div class="footer-bottom">
    <p>© 2026 Raccodynamx. All rights reserved.</p>
  </div>
</footer>

<style>
.footer {
  background: var(--navy-900);
  position: relative;
}

.footer-accent-top {
  height: 3px;
  background: var(--navy-300);
}

.footer-inner {
  display: flex;
  gap: 64px;
  padding: 40px 48px 24px;
}

.footer-brand {
  flex: 0 0 200px;
}

.footer-logo {
  font-family: 'Schibsted Grotesk', sans-serif;
  font-weight: 800;
  font-size: 16px;
  color: white;
  letter-spacing: 1px;
  margin-bottom: 6px;
}

.footer-tagline {
  font-size: 12px;
  color: var(--navy-300);
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer-col-title {
  font-size: 16px;
  font-weight: 400;
  color: white;
  margin-bottom: 2px;
}

.footer-link {
  font-size: 12px;
  color: var(--navy-300);
  transition: color 0.2s;
  display: block;
}

.footer-link:hover {
  color: var(--navy-200);
}

.footer-bottom {
  padding: 0 48px 24px;
  font-size: 11px;
  color: #738cb2;
}

@media (max-width: 768px) {
  .footer-inner { flex-wrap: wrap; padding: 32px 24px 16px; gap: 32px; }
  .footer-bottom { padding: 0 24px 24px; }
}
</style>
